rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Profilo utente: lettura/scrittura solo del proprio documento (email, token FCM, posizione non esposti agli altri client).
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Emergenze: lettura per utenti loggati; creazione/aggiornamento solo per il proprietario dell'allarme.
    match /emergencies/{emergencyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }
  }
}
