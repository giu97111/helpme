# Copia questo file come .env nella stessa cartella (functions/.env).
# Valori usati da firebase-functions/params (vedi index.js).

# true = invia FCM a tutti gli utenti con token (ignora distanza), solo per test
SCUDO_BROADCAST_ALL=false

# Opzionale: URL HTTPS pubblico per immagine nelle push (il server non ha l’asset dell’app)
SCUDO_NOTIFICATION_IMAGE_URL=
