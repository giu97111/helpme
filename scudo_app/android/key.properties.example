# Copia come `key.properties` nella cartella `android/` e compila i valori.
# Non committare `key.properties` (è in .gitignore).
#
# Generazione keystore (esempio):
#   keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# storeFile è relativo alla cartella `android/` (es. file nella cartella home del progetto).
storePassword=your_store_password
keyPassword=your_key_password
keyAlias=upload
storeFile=../upload-keystore.jks
